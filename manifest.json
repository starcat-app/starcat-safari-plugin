{
  "manifest_version": 3,
  "name": "Starcat Safari Plugin",
  "description": "Show Starcat context on GitHub repository pages in Safari.",
  "version": "0.1.0",
  "icons": {
    "16": "src/assets/icons/icon-16.png",
    "32": "src/assets/icons/icon-32.png",
    "48": "src/assets/icons/icon-48.png",
    "128": "src/assets/icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://github.com/*",
    "https://*/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://*/search*"],
      "js": ["src/shared/shared.js", "src/content/content-script.js"],
      "css": ["src/content/content-script.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/assets/icons/*.png", "src/assets/starcat-menu/*.png"],
      "matches": ["https://github.com/*", "https://*/*"]
    }
  ],
  "action": {
    "default_title": "Starcat Safari Plugin",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/icons/icon-16.png",
      "32": "src/assets/icons/icon-32.png",
      "48": "src/assets/icons/icon-48.png",
      "128": "src/assets/icons/icon-128.png"
    }
  },
  "options_page": "src/options/options.html"
}
